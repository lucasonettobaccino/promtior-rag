# Application
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=console

# OpenAI
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# Cohere
COHERE_API_KEY=
RERANK_MODEL=rerank-english-v3.0
RERANK_TOP_N=4

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=promtior-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Data sources
PROMTIOR_WEB_URL=https://promtior.ai/
PROMTIOR_WEB_MAX_DEPTH=3
PROMTIOR_PDF_PATH=./data/AI_Engineer.pdf

# Indexing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
VECTOR_STORE_PATH=./data/vector_store

# Retrieval
RETRIEVER_TOP_K=10
RETRIEVER_SEMANTIC_WEIGHT=0.6

# API server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=*